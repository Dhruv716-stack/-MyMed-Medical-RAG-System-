# Python virtual environments
venv/
.venv/
.venv-win/

# Python cache
__pycache__/
*.pyc

# Local environment files
.env

# Ignore local notebook scratch/testing files
test.ipynb
test1.ipynb
qdrant_data/

# Ignore package marker file in pre_retrieval
pre_retrieval/__init__.py
chat_memory.db

# Keep data/ folder structure in repo, but never commit users' uploaded files
data/user_uploads/*
!data/user_uploads/.gitkeep

# Runtime artifacts from the FastAPI app
logs/
uploads/

# Qdrant's live database files (created/rewritten by the docker container on
# every run). These are generated data, not source: tracking them made the
# working tree permanently dirty and bloated the repo. The container recreates
# the folder automatically, so only the mount point needs to exist.
docker/qdrant/storage/
!docker/qdrant/storage/.gitkeep

# Evaluation cache generated by evaluation/ragas.py
evaluation/dataset_dict_cache.json
pyrightconfig.json
